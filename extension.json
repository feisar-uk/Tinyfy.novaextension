{
    "identifier": "feisar.Tinyfy",
    "name": "Tinyfy",
    "organization": "Feisar",
    "description": "Automatically minify local CSS & JS files on save using Lightning CSS and Terser.",
    "version": "1.4",
    "categories": ["formatters"],
    "repository": "https://github.com/feisar-uk/Tinyfy.novaextension",
    "bugs": "https://github.com/feisar-uk/Tinyfy.novaextension/issues",
    "main": "main.js",

    "activationEvents": [
        "onLanguage:javascript",
        "onLanguage:css"
    ],

    "entitlements": {
        "process": true,
        "filesystem": "readwrite"
    },

    "config": [{

            "title": "Terser",
            "type": "section",
            "description": "Options for Terser JavaScript minification",
            "children": [{
                    "key": "terser.enabled",
                    "title": "Enable JavaScript minification on save",
                    "type": "boolean",
                    "default": true
                },
                {
                    "key": "terser.outputSuffix",
                    "title": "JS Output Suffix",
                    "type": "string",
                    "default": ".min.js"
                },
                {
                    "key": "terser.enableCompress",
                    "title": "Enable Compression",
                    "description": "Passes --compress to Terser",
                    "link": "https://terser.org/docs/cli-usage/#cli-compress-options",
                    "type": "boolean",
                    "default": true
                },
                {
                    "key": "terser.enableMangle",
                    "title": "Enable Mangling",
                    "description": "Passes --mangle to Terser",
                    "link": "https://terser.org/docs/cli-usage/#cli-mangle-options",
                    "type": "boolean",
                    "default": true
                },
                {
                    "key": "terser.additionalArgs",
                    "title": "Additional Terser Flags",
                    "description": "Extra CLI flags appended to the Terser command, space separated (e.g. --module --toplevel)",
                    "link": "https://terser.org/docs/cli-usage/#command-line-options",
                    "type": "string",
                    "default": ""
                },
                {
                    "key": "terser.trimOutput",
                    "title": "Trim Trailing Whitespace",
                    "description": "Removes the trailing newline Terser's CLI appends to minified output",
                    "type": "boolean",
                    "default": true
                }
            ]
        },
        {
            "title": "Lightning CSS",
            "description": "Options for Lightning CSS minification",
            "type": "section",
            "children": [{
                    "key": "lightningcss.enabled",
                    "title": "Enable CSS minification on save",
                    "type": "boolean",
                    "default": true
                },
                {
                    "key": "lightningcss.outputSuffix",
                    "title": "CSS Output Suffix",
                    "type": "string",
                    "default": ".min.css"
                },
                {
                    "key": "lightningcss.enableNesting",
                    "title": "Enable Native CSS Nesting",
                    "link": "https://lightningcss.dev/transpilation.html#nesting",
                    "description": "Passes --nesting to Lightning CSS",
                    "type": "boolean",
                    "default": false
                },
                {
                    "key": "lightningcss.enableCustomMedia",
                    "title": "Enable Custom Media Queries",
                    "link": "https://lightningcss.dev/transpilation.html#custom-media-queries",
                    "description": "Passes --custom-media to Lightning CSS",
                    "type": "boolean",
                    "default": false
                },
                {
                    "key": "lightningcss.enableErrorRecovery",
                    "title": "Enable Error Recovery",
                    "link": "https://lightningcss.dev/docs.html#error-recovery",
                    "description": "Passes --error-recovery to Lightning CSS, allowing it to skip invalid rules instead of failing",
                    "type": "boolean",
                    "default": false
                },
                {
                    "key": "lightningcss.targets",
                    "title": "Browser Targets",
                    "link": "https://browsersl.ist",
                    "description": "A browserslist query passed via --targets (e.g. \"last 2 versions, > 1%\"), used for autoprefixing and syntax lowering",
                    "type": "string",
                    "default": ""
                },
                {
                    "key": "lightningcss.additionalArgs",
                    "title": "Additional Lightning CSS Flags",
                    "link": "https://lightningcss.dev/docs.html#from-the-cli",
                    "description": "Extra CLI flags appended to the Lightning CSS command, space separated (e.g. --source-map)",
                    "type": "string",
                    "default": ""
                }
            ]
        }
    ]
}
